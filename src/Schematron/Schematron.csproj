<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <OutputPath>..\bin\$(Configuration)\</OutputPath>
    <DocumentationFile>$(OutputPath)Schematron.xml</DocumentationFile>
    <GitVersionFile>VERSION</GitVersionFile>
  </PropertyGroup>
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AssemblyTitle>Schematron.NET</AssemblyTitle>
    <Description>A C# native .NET implementation of the Schematron ISO/IEC standard</Description>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="..\GlobalAssemblyInfo.cs">
      <Link>Properties\GlobalAssemblyInfo.cs</Link>
    </Compile>
    <Content Include="Formatters\XmlFormatter.xsd" />
    <None Update="Formatters\XmlFormatter.xsx">
      <DependentUpon>XmlFormatter.xsd</DependentUpon>
    </None>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="GitInfo" Version="3.3.5">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="AsyncAssertEvaluate.cs" />
    <Compile Remove="AsyncEvaluationContext.cs" />
    <Compile Remove="AsyncReportEvaluate.cs" />
  </ItemGroup>
</Project>